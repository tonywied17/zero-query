{
  "name": "zero-query",
  "version": "0.9.0",
  "description": "Lightweight modern frontend library — jQuery-like selectors, reactive components, SPA router, and state management with zero dependencies.",
  "main": "index.js",
  "types": "index.d.ts",
  "bin": {
    "zquery": "cli/index.js"
  },
  "files": [
    "src",
    "tests",
    "dist",
    "cli",
    "types",
    "index.js",
    "index.d.ts",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "node cli/index.js build",
    "dev": "node cli/index.js dev zquery-website",
    "dev:bundle": "node cli/index.js dev zquery-website --bundle",
    "dev-lib": "node cli/index.js build --watch",
    "bundle": "node cli/index.js bundle",
    "bundle:app": "node cli/index.js bundle zquery-website",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "dom",
    "query",
    "selector",
    "components",
    "spa",
    "router",
    "reactive",
    "lightweight",
    "frontend",
    "zero",
    "zquery",
    "zero-dependency"
  ],
  "author": "Anthony Wiedman",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tonywied17/zero-query.git"
  },
  "bugs": {
    "url": "https://github.com/tonywied17/zero-query/issues"
  },
  "homepage": "https://z-query.com/docs",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "jsdom": "^28.1.0",
    "vitest": "^4.0.18",
    "zero-http": "^0.2.3"
  }
}
